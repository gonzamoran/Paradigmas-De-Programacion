Object subclass: #DiaDomingo	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'Calendario'!!DiaDomingo methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 20:42'!coincideCon: aFecha	^((aFecha dayOfWeek) = 1)	! !Object subclass: #Calendario	instanceVariableNames: 'feriados'	classVariableNames: ''	poolDictionaries: ''	category: 'Calendario'!!Calendario methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 20:04'!agregarFeriado: aFeriado 		feriados add: aFeriado.! !!Calendario methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 20:26'!esFeriado: aFecha 		feriados do: [ 		:feriado |		(feriado esFeriado: aFecha) ifTrue: [^true].		].	^false.! !!Calendario methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 20:05'!initialize 	feriados := OrderedCollection new.! !Object subclass: #Feriado	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'Calendario'!Feriado subclass: #FeriadoRestringidoPorAnio	instanceVariableNames: 'feriadoAnual anioDesde anioHasta'	classVariableNames: ''	poolDictionaries: ''	category: 'Calendario'!!FeriadoRestringidoPorAnio methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 22:15'!esFeriado: aFecha 		(anioDesde = nil) ifFalse: [		(aFecha year >= anioDesde) ifFalse: [^false].	].	(anioHasta = nil) ifFalse: [		(aFecha year <= anioHasta) ifFalse: [^false].	].		^(feriadoAnual esFeriado: aFecha).! !!FeriadoRestringidoPorAnio methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 22:07'!setAnioDesde: aAnio	anioDesde := aAnio.! !!FeriadoRestringidoPorAnio methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 22:07'!setAnioHasta: aAnio	anioHasta := aAnio.! !!FeriadoRestringidoPorAnio methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 21:09'!setFeriadoAnual: aFeriadoAnual 	feriadoAnual := aFeriadoAnual.! !Feriado subclass: #FeriadoSemanal	instanceVariableNames: 'elDia'	classVariableNames: ''	poolDictionaries: ''	category: 'Calendario'!!FeriadoSemanal methodsFor: 'private' stamp: 'e 9/6/2012 20:03'!setDiaSemana: aDia 	elDia := aDia.! !!FeriadoSemanal methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 20:35'!esFeriado: aFecha 	^(elDia coincideCon: aFecha)! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!FeriadoSemanal class	instanceVariableNames: ''!!FeriadoSemanal class methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 20:01'!conDia: aDia 		| unFeriado|		unFeriado := self new.  "es lo mismo que (FeriadoSemanal new)"	"si estamos aca, ya se ejecuto el initialize de FeriadoSemanal"		unFeriado setDiaSemana: aDia.	     ^unFeriado.! !FeriadoRestringidoPorAnio subclass: #FeriadoAPartirDeAnio	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'Calendario'!"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!FeriadoAPartirDeAnio class	instanceVariableNames: ''!!FeriadoAPartirDeAnio class methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 22:10'!enDia: aDia deMes: aMes aPartirDeAnio: aAnio 		| unFeriado |	unFeriado := self new.	unFeriado setFeriadoAnual: (FeriadoAnual enDia: aDia deMes: aMes).	unFeriado setAnioDesde: aAnio.		^unFeriado.! !Feriado subclass: #FeriadoAnual	instanceVariableNames: 'elDia elMes'	classVariableNames: ''	poolDictionaries: ''	category: 'Calendario'!!FeriadoAnual methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 20:54'!esFeriado: aFecha 	^((aFecha dayOfMonth) = elDia) & ((aFecha monthIndex) = elMes).! !!FeriadoAnual methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 20:49'!setDia: aDia 	elDia := aDia.! !!FeriadoAnual methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 20:49'!setMes: aMes 	elMes := aMes.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!FeriadoAnual class	instanceVariableNames: ''!!FeriadoAnual class methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 20:48'!enDia: aDia deMes: aMes 		| unFeriado |	unFeriado := self new.	unFeriado setDia: aDia.     unFeriado setMes: aMes.	^unFeriado.! !FeriadoRestringidoPorAnio subclass: #FeriadoPuntual	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'Calendario'!"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!FeriadoPuntual class	instanceVariableNames: ''!!FeriadoPuntual class methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 22:09'!enDia: aDia deMes: aMes deAnio: aAnio 		| unFeriado |	unFeriado := self new.	unFeriado setFeriadoAnual: (FeriadoAnual enDia: aDia deMes: aMes).	unFeriado setAnioDesde: aAnio.	unFeriado setAnioHasta: aAnio.		^unFeriado.! !