TestCase subclass: #TestCalendario	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'CalendarioTests'!!TestCalendario methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 22:12'!test24MarFeriado	| unCalendario unFeriado |		unCalendario := Calendario new.	unFeriado := FeriadoAPartirDeAnio enDia: 24 deMes: 3 aPartirDeAnio: 2006.		unCalendario agregarFeriado: unFeriado.		self should: (unCalendario esFeriado: (Date newDay: 24 month: 3 year: 2008)).! !!TestCalendario methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 22:11'!test24Sept2012Feriado	| unCalendario unFeriado |		unCalendario := Calendario new.	unFeriado := FeriadoPuntual enDia: 24 deMes: 9 deAnio: 2012.		unCalendario agregarFeriado: unFeriado.		self should: (unCalendario esFeriado: (Date newDay: 24 month: 9 year: 2012)).	! !!TestCalendario methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 19:48'!testDomingoFeriado	|unCalendario unFeriado resultado unaFecha|		unCalendario := Calendario new.		unFeriado := FeriadoSemanal conDia: (DiaDomingo new).		unCalendario agregarFeriado: unFeriado.	unaFecha := Date newDay: 9 month: 9 year: 2012.		resultado := unCalendario esFeriado: (unaFecha).	self should: (resultado).	! !!TestCalendario methodsFor: 'as yet unclassified' stamp: 'e 9/6/2012 20:46'!testNavidadFeriado	| unCalendario unFeriado |		unCalendario := Calendario new.	unFeriado := FeriadoAnual enDia: 25 deMes: 12.		unCalendario agregarFeriado: unFeriado.		self should: (unCalendario esFeriado: (Date newDay: 25 month: 12 year: 2012)).	! !