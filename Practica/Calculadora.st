Object subclass: #Calculadora	instanceVariableNames: 'inflacion'	classVariableNames: ''	package: 'Calculadora'!!Calculadora methodsFor: 'as yet unclassified' stamp: 'Anonymous 3/26/2024 21:08'!ajustar: unNumero	^ unNumero + (unNumero * (inflacion / 100)) .! !!Calculadora methodsFor: 'as yet unclassified' stamp: 'Anonymous 3/26/2024 21:02'!establecerAjusteDeInflacion: unNumero	inflacion := unNumero.! !!Calculadora methodsFor: 'as yet unclassified' stamp: 'Joaquin 9/6/2025 14:29'!factorial: unNumero	^ unNumero factorial.! !!Calculadora methodsFor: 'as yet unclassified' stamp: 'Anonymous 3/26/2024 20:04'!sumar: unNumero con: otroNumero	^ unNumero + otroNumero.! !!Calculadora methodsFor: 'as yet unclassified' stamp: 'Anonymous 3/26/2024 20:29'!multiplicar: unNumero con: otroNumero	^ (unNumero * otroNumero) roundTo: 0.01.! !!Calculadora methodsFor: 'initialization' stamp: 'Anonymous 3/26/2024 21:12'!initialize 	inflacion := 0.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Calculadora class	instanceVariableNames: ''!!Calculadora class methodsFor: 'as yet unclassified' stamp: 'Anonymous 3/26/2024 21:00'!conAjusteDeInflacion: unaInflacion	| calculadora |	calculadora := self new.	calculadora establecerAjusteDeInflacion: unaInflacion.	^ calculadora.! !TestCase subclass: #CalculadoraTest	instanceVariableNames: ''	classVariableNames: ''	package: 'Calculadora'!!CalculadoraTest methodsFor: 'tests' stamp: 'Anonymous 3/26/2024 21:14'!test07ComienzaConAjusteCero	"Arrange"	| calculadora resultado esperado |	calculadora := Calculadora new.	esperado := 500000.		"Act"	resultado := calculadora ajustar: 500000.		"Assert"	self assert: resultado equals: esperado.! !!CalculadoraTest methodsFor: 'tests' stamp: 'Anonymous 3/26/2024 20:16'!test03ProductoConFlotantes	"Arrange"	| calculadora resultado esperado |	calculadora := Calculadora new.	esperado := 11.48.		"Act"	resultado := calculadora multiplicar: 5.15 con: 2.23.		"Assert"	self assert: resultado equals: esperado.! !!CalculadoraTest methodsFor: 'tests' stamp: 'Anonymous 3/26/2024 20:11'!test02SumaDeEnteroConFlotante	"Arrange"	| calculadora resultado esperado |	calculadora := Calculadora new.	esperado := 10.0.		"Act"	resultado := calculadora sumar: 3 con: 7.0.		"Assert"	self assert: resultado equals: esperado.! !!CalculadoraTest methodsFor: 'tests' stamp: 'Anonymous 3/26/2024 20:24'!test04ProductoConEnteroyFlotante	"Arrange"	| calculadora resultado esperado |	calculadora := Calculadora new.	esperado := 23.75.		"Act"	resultado := calculadora multiplicar: 5 con: 4.75.		"Assert"	self assert: resultado equals: esperado.! !!CalculadoraTest methodsFor: 'tests' stamp: 'Anonymous 3/26/2024 20:43'!test05FactorialDeEntero	"Arrange"	| calculadora resultado esperado |	calculadora := Calculadora new.	esperado := 24.		"Act"	resultado := calculadora factorial: 4.		"Assert"	self assert: resultado equals: esperado.! !!CalculadoraTest methodsFor: 'tests' stamp: 'Anonymous 3/26/2024 20:03'!test01SumaDeEnteros	| calculadora resultado esperado |		"Arrange"	calculadora := Calculadora new.	esperado := 30.		"Act"	resultado := calculadora sumar: 10 con: 20.		"Assert"	self assert: resultado equals: esperado ! !!CalculadoraTest methodsFor: 'tests' stamp: 'Anonymous 3/26/2024 20:54'!test06CalculaAjusteDeInflacion	"Arrange"	| calculadora resultado esperado |	calculadora := Calculadora conAjusteDeInflacion: 14.0.	esperado := 570000.		"Act"	resultado := calculadora ajustar: 500000.		"Assert"	self assert: resultado equals: esperado.! !