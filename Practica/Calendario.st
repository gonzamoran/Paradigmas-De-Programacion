Object subclass: #Calendario	instanceVariableNames: 'feriados'	classVariableNames: ''	package: 'Calendario'!!Calendario methodsFor: 'initialization' stamp: 'SV 9/4/2025 21:46'!initialize	feriados := OrderedCollection new.! !!Calendario methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:45'!agregar: unFeriado 	feriados add: unFeriado.! !!Calendario methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:50'!esFeriado: unaFecha 	^feriados anySatisfy: [ :feriado | feriado esFeriado: unaFecha ].! !Object subclass: #Feriado	instanceVariableNames: ''	classVariableNames: ''	package: 'Calendario'!!Feriado methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:51'!esFeriado: unaFecha	self subclassResponsibility.! !Feriado subclass: #FeriadoAPartirDeAño	instanceVariableNames: 'dia mes aPartirDe'	classVariableNames: ''	package: 'Calendario'!!FeriadoAPartirDeAño methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:39'!enDia: unDia del: unMes desde: desde 	dia := unDia.	mes := unMes.	aPartirDe := desde.! !!FeriadoAPartirDeAño methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:41'!esFeriado: unaFecha 	^((unaFecha dayOfMonth = dia) and: unaFecha monthIndex = mes) and: (unaFecha year >= aPartirDe).! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!FeriadoAPartirDeAño class	instanceVariableNames: ''!!FeriadoAPartirDeAño class methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:37'!enDia: unDia del: unMes desde: unAño	| instancia |	instancia := self new.	instancia enDia: unDia del: unMes desde: unAño.	^instancia.! !Feriado subclass: #FeriadoAnual	instanceVariableNames: 'mes dia'	classVariableNames: ''	package: 'Calendario'!!FeriadoAnual methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:29'!esFeriado: unaFecha 	^(unaFecha dayOfMonth = dia) and: unaFecha monthIndex = mes.! !!FeriadoAnual methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:28'!enDia: unDia del: unMes 	dia:= unDia.	mes := unMes.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!FeriadoAnual class	instanceVariableNames: ''!!FeriadoAnual class methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:27'!enDia: unDia del: unMes 	| instancia |	instancia := self new.	instancia enDia: unDia del: unMes.	^instancia.! !Feriado subclass: #FeriadoPuntual	instanceVariableNames: 'dia mes año'	classVariableNames: ''	package: 'Calendario'!!FeriadoPuntual methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:34'!esFeriado: unaFecha 	^((unaFecha dayOfMonth = dia) and: unaFecha monthIndex = mes) and: (unaFecha year = año).! !!FeriadoPuntual methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:33'!enDia: unDia del: unMes del: unAño 	dia:= unDia.	mes := unMes.	año := unAño.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!FeriadoPuntual class	instanceVariableNames: ''!!FeriadoPuntual class methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:31'!enDia: unDia del: unMes del: unAño 	| instancia |	instancia := self new.	instancia enDia: unDia del: unMes del: unAño.	^instancia.! !Feriado subclass: #FeriadoSemanal	instanceVariableNames: 'dia'	classVariableNames: ''	package: 'Calendario'!!FeriadoSemanal methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:24'!esFeriado: unaFecha 	^unaFecha weekday = dia.! !!FeriadoSemanal methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:22'!enDia: unDia 	dia := unDia.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!FeriadoSemanal class	instanceVariableNames: ''!!FeriadoSemanal class methodsFor: 'as yet unclassified' stamp: 'SV 9/4/2025 21:22'!enDia: unDia 	| instancia |	instancia := self new.	instancia enDia: unDia.	^instancia.! !