TestCase subclass: #CalendarioTest	instanceVariableNames: ''	classVariableNames: ''	package: 'Calendario-Test'!!CalendarioTest methodsFor: 'tests' stamp: 'SV 9/4/2025 21:35'!test04El24DeMarzo2006EsFeriadoDesdeEseAño	| fecha feriado esFeriado |	fecha := Date newDay: 24 month: 03 year: 2008.		feriado := FeriadoAPartirDeAño enDia: 24 del: 03 desde: 2006.		esFeriado := feriado esFeriado: fecha.		self assert: esFeriado.! !!CalendarioTest methodsFor: 'tests' stamp: 'SV 9/4/2025 21:30'!test03El20DeDiciembre2022FueFeriado	| copaDelMundo feriado esFeriado |	copaDelMundo := Date newDay: 20 month: 12 year: 2022.		feriado := FeriadoPuntual enDia: 20 del: 12 del: 2022.		esFeriado := feriado esFeriado: copaDelMundo.		self assert: esFeriado.! !!CalendarioTest methodsFor: 'tests' stamp: 'SV 9/4/2025 21:26'!test02NavidadEsFeriado	| navidad feriado esFeriado |	navidad := Date newDay: 25 month: 12 year: 2025.		feriado := FeriadoAnual enDia: 25 del: 12.		esFeriado := feriado esFeriado: navidad.		self assert: esFeriado.! !!CalendarioTest methodsFor: 'tests' stamp: 'SV 9/4/2025 21:45'!test01LosDomingosSonFeriado	| domingo feriado esFeriado calendario |	domingo := Date newDay: 31 month: 8 year: 2025.	calendario := Calendario new.	feriado := FeriadoSemanal enDia: #Sunday.	calendario agregar: feriado.		esFeriado := calendario esFeriado: domingo.		self assert: esFeriado.! !