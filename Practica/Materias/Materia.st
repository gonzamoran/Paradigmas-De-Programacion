Object subclass: #Alumno	instanceVariableNames: 'nombre padron genero'	classVariableNames: ''	package: 'Materia'!!Alumno methodsFor: 'not defined category' stamp: 'SV 9/16/2024 18:21'!tienePadron: unPadron 	^(padron = unPadron).! !!Alumno methodsFor: 'not defined category' stamp: 'SV 9/16/2024 19:43'!entraEnElCupo: unaMateria 	genero restarCupo: unaMateria.! !!Alumno methodsFor: 'as yet unclassified' stamp: 'SV 9/16/2024 19:43'!conNombre: unNombre Padron: unPadron yGenero: unGenero	nombre := unNombre.	padron := unPadron.	genero := Genero deLetra: unGenero.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Alumno class	instanceVariableNames: ''!!Alumno class methodsFor: 'not defined category' stamp: 'SV 9/16/2024 19:01'!conNombre: unNombre Padron: unPadron yGenero: unGenero	| unAlumno |	unAlumno := self new.	unAlumno conNombre: unNombre Padron: unPadron yGenero: unGenero.	^unAlumno! !!Alumno class methodsFor: 'not defined category' stamp: 'SV 9/16/2024 18:19'!conNombre: unNombre yPadron: unPadron 	| unAlumno |	unAlumno := self new.	unAlumno conNombre: unNombre yPadron: unPadron.	^unAlumno! !Error subclass: #AlumnoNoInscriptoError	instanceVariableNames: ''	classVariableNames: ''	package: 'Materia'!TestCase subclass: #AlumnoTest	instanceVariableNames: ''	classVariableNames: ''	package: 'Materia'!!AlumnoTest methodsFor: 'tests' stamp: 'SV 9/16/2024 19:31'!test02UnAlumnoTieneGeneroYSabeIndicarSiEntraEnElCupo	| unAlumno unaMateria |	unaMateria := Materia conCupoPorGeneroH: 30 M: 30 O: 40.	unAlumno := Alumno conNombre: 'Tomas' Padron: '111111' yGenero: 'H'.	self shouldnt: [unAlumno entraEnElCupo: unaMateria] raise: [ CupoExcedidoError ].	! !!AlumnoTest methodsFor: 'tests' stamp: 'SV 9/16/2024 19:48'!test01UnAlumnoSabeIndicarSuPadron	| unAlumno |	unAlumno := Alumno conNombre: 'Tomas' Padron: '111111' yGenero: 'H'.		self assert: (unAlumno tienePadron: '111111').	! !Error subclass: #CupoExcedidoError	instanceVariableNames: ''	classVariableNames: ''	package: 'Materia'!Object subclass: #Genero	instanceVariableNames: ''	classVariableNames: ''	package: 'Materia'!!Genero methodsFor: 'as yet unclassified' stamp: 'SV 9/16/2024 19:37'!restarCupo: unaMateria 	self subclassResponsibility.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Genero class	instanceVariableNames: ''!!Genero class methodsFor: 'as yet unclassified' stamp: 'SV 9/16/2024 19:35'!deLetra: unaLetra 	(unaLetra = 'H') ifTrue: [ ^Hombre new. ].	(unaLetra = 'M') ifTrue: [ ^Mujer new. ].	^Otro new.! !TestCase subclass: #GeneroTest	instanceVariableNames: ''	classVariableNames: ''	package: 'Materia'!!GeneroTest methodsFor: 'tests' stamp: 'SV 9/16/2024 19:36'!test01UnGeneroRestaElCupoCorrespondiente	| unaMateria hombre |	unaMateria := Materia conCupoPorGeneroH: 30 M: 30 O: 40.	hombre := Genero deLetra: 'H'. 		self shouldnt: [hombre restarCupo: unaMateria] raise: CupoExcedidoError.! !!GeneroTest methodsFor: 'tests' stamp: 'SV 9/16/2024 19:38'!test02UnGeneroMRestaElCupoCorrespondiente	| unaMateria hombre |	unaMateria := Materia conCupoPorGeneroH: 30 M: 30 O: 40.	hombre := Genero deLetra: 'M'. 		self shouldnt: [hombre restarCupo: unaMateria] raise: CupoExcedidoError.! !!GeneroTest methodsFor: 'tests' stamp: 'SV 9/16/2024 19:40'!test03UnGeneroMRestaElCupoCorrespondiente	| unaMateria hombre |	unaMateria := Materia conCupoPorGeneroH: 30 M: 30 O: 40.	hombre := Genero deLetra: 'O'. 		self shouldnt: [hombre restarCupo: unaMateria] raise: CupoExcedidoError.! !Genero subclass: #Hombre	instanceVariableNames: ''	classVariableNames: ''	package: 'Materia'!!Hombre methodsFor: 'as yet unclassified' stamp: 'SV 9/16/2024 19:37'!restarCupo: unaMateria	unaMateria restarCupoH.	! !Object subclass: #Materia	instanceVariableNames: 'alumnos cupo cupoH cupoM cupoO'	classVariableNames: ''	package: 'Materia'!!Materia methodsFor: 'not defined category' stamp: 'SV 9/16/2024 19:00'!conCupoPorGeneroH: unCupoH M: unCupoM O: unCupoO 	cupo := unCupoH + unCupoM + unCupoO .	cupoH := unCupoH.	cupoM := unCupoM.	cupoO := unCupoO.! !!Materia methodsFor: 'not defined category' stamp: 'SV 9/16/2024 19:45'!registrar: unAlumno 	(cupo = 0) ifTrue: [ CupoExcedidoError signal. ].	unAlumno entraEnElCupo: self.	alumnos add: unAlumno.	cupo := cupo - 1.! !!Materia methodsFor: 'not defined category' stamp: 'SV 9/16/2024 18:33'!obtenerAlumno: unPadron 	| alumno |	alumno := alumnos detect: [ :unAlumno | unAlumno tienePadron: unPadron ] ifNone: [ AlumnoNoInscriptoError signal]. 	^alumno! !!Materia methodsFor: 'not defined category' stamp: 'SV 9/16/2024 19:40'!restarCupoH	cupoH := self restarCupo: cupoH.! !!Materia methodsFor: 'initialization' stamp: 'SV 9/16/2024 18:24'!initialize 	alumnos := OrderedCollection new.! !!Materia methodsFor: 'as yet unclassified' stamp: 'SV 9/16/2024 19:40'!restarCupo: unCupo	(unCupo = 0) ifTrue: [ CupoExcedidoError signal ].	^unCupo - 1.! !!Materia methodsFor: 'as yet unclassified' stamp: 'SV 9/16/2024 17:39'!conCupo: unCupo 	cupo := unCupo.! !!Materia methodsFor: 'as yet unclassified' stamp: 'SV 9/16/2024 19:40'!restarCupoM	cupoM := self restarCupo: cupoM.! !!Materia methodsFor: 'as yet unclassified' stamp: 'SV 9/16/2024 19:41'!restarCupoO	cupoO := self restarCupo: cupoO.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Materia class	instanceVariableNames: ''!!Materia class methodsFor: 'not defined category' stamp: 'SV 9/16/2024 18:59'!conCupoPorGeneroH: cupoH M: cupoM O: cupoO 	| materia |	materia := self new.	materia conCupoPorGeneroH: cupoH M: cupoM O: cupoO.	^materia! !!Materia class methodsFor: 'not defined category' stamp: 'SV 9/16/2024 17:39'!conCupo: unCupo 	| materia |	materia := self new.	materia conCupo: unCupo.	^materia.! !TestCase subclass: #MateriaTest	instanceVariableNames: ''	classVariableNames: ''	package: 'Materia'!!MateriaTest methodsFor: 'tests' stamp: 'SV 9/16/2024 19:47'!test03AUnaMateriaSeLePuedenInscribirAlumnosHastaElCupo	| unaMateria alumno alumnoEsperado |	unaMateria := Materia conCupoPorGeneroH: 30 M: 30  O: 40.	alumnoEsperado := Alumno conNombre: 'Tomas' Padron: 111111 yGenero: 'H'.		unaMateria registrar: alumnoEsperado.	unaMateria registrar: (Alumno conNombre: 'Matias' Padron: 222222 yGenero: 'H').		alumno := unaMateria obtenerAlumno: 111111.		self assert: alumno equals: alumnoEsperado.			! !!MateriaTest methodsFor: 'tests' stamp: 'SV 9/16/2024 19:44'!test01AUnaMateriaSeLePuedenInscribirAlumnos	| unaMateria  alumnoEsperado alumnoObtenido |	unaMateria := Materia conCupoPorGeneroH: 30 M: 30  O: 40 .	alumnoEsperado := Alumno conNombre: 'Tomas' Padron: 111111 yGenero: 'H'.		unaMateria registrar: alumnoEsperado.		alumnoObtenido := unaMateria obtenerAlumno: 111111.		self assert: alumnoObtenido equals: alumnoEsperado.			! !!MateriaTest methodsFor: 'tests' stamp: 'SV 9/16/2024 19:46'!test02AUnaMateriaNoSePuedeObtenerUnALumnoNoInscripto	| unaMateria alumno |	unaMateria := Materia conCupoPorGeneroH: 30 M: 30  O: 40.	alumno := Alumno conNombre: 'Tomas' Padron: 111111 yGenero: 'H'.		unaMateria registrar: alumno.		self should: [ unaMateria obtenerAlumno: 222222. ] raise: AlumnoNoInscriptoError.! !!MateriaTest methodsFor: 'tests' stamp: 'SV 9/16/2024 19:48'!test04AUnaMateriaNoSePuedenInscribirAlumnosPasadoElCupo	| unaMateria |	unaMateria := Materia conCupoPorGeneroH: 2 M: 0  O: 0 .		unaMateria registrar: (Alumno conNombre: 'Tomas' Padron: 111111 yGenero: 'H').	unaMateria registrar: (Alumno conNombre: 'Matias' Padron: 222222 yGenero: 'H').	self should: [ unaMateria registrar: (Alumno conNombre: 'Pablo' Padron: 333333  yGenero: 'H'). ] raise: CupoExcedidoError .			! !Genero subclass: #Mujer	instanceVariableNames: ''	classVariableNames: ''	package: 'Materia'!!Mujer methodsFor: 'as yet unclassified' stamp: 'SV 9/16/2024 19:38'!restarCupo: unaMateria	unaMateria restarCupoM.! !Genero subclass: #Otro	instanceVariableNames: ''	classVariableNames: ''	package: 'Materia'!!Otro methodsFor: 'as yet unclassified' stamp: 'SV 9/16/2024 19:38'!restarCupo: unaMateria	unaMateria restarCupoO! !