TestCase subclass: #AlgoConsejosTests	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1 -Casos-de-Uso'!!AlgoConsejosTests methodsFor: 'tests' stamp: 'Gonzalo 9/25/2025 01:10'!test01AlgoConsejoDevuelveMasCaro	| futbolistaMasCaroEsperado futbolistaMasCaroObtenido algoConsejo |		"Arrange"		futbolistaMasCaroEsperado := 'Marco Pellegrino'.	algoConsejo  := AlgoConsejo conCriterioMas: 'Caro'.		algoConsejo registrarFutbolistaConNombre: 'Kevin Zenon' dePeso: 72  yAltura: 1.77 yEdad: 24 yProvenienteDelClub: 'Union de Santa Fe' DePais: 'Argentina'.	algoConsejo registrarFutbolistaConNombre: 'Marco Pellegrino' dePeso: 79  yAltura: 1.84 yEdad: 23 yProvenienteDelClub: 'AC Milan' DePais: 'Italia'.		"Act"	futbolistaMasCaroObtenido := algoConsejo obtenerFutbolistaSegunCriterio.		"Assert"	self assert: futbolistaMasCaroObtenido equals: futbolistaMasCaroEsperado .! !!AlgoConsejosTests methodsFor: 'tests' stamp: 'Gonzalo 10/16/2025 12:16'!test04JugadorNoEncontrado 	"Act"	|bloque  consejo|	consejo := AlgoConsejo conCriterioMas: 'Caro'.	consejo registrarFutbolistaConNombre: 'Kevin Zenon' dePeso: 72  yAltura: 1.77 yEdad: 24 yProvenienteDelClub: 'Union de Santa Fe' DePais: 'Argentina'.		"Act"	bloque  := [consejo valorDe: 'Messi' ].		"Assert"	self should: bloque raise: FutbolistaNoEncontradoError .! !!AlgoConsejosTests methodsFor: 'tests' stamp: 'Gonzalo 10/16/2025 12:16'!test02ColeccionJugadoresVacia 	"Act"	|bloque  consejo|	consejo := AlgoConsejo conCriterioMas: 'Caro'.			"Act"	bloque  := [consejo obtenerFutbolistaSegunCriterio ].		"Assert"	self should: bloque raise: ColeccionVaciaError .! !!AlgoConsejosTests methodsFor: 'tests' stamp: 'Gonzalo 10/17/2025 09:04'!test03CriterioInvalido 	"Act"	|bloque |		"Act"	bloque  := [Criterio conCriterio:  'Desconocido' ].		"Assert"	self should: bloque raise: CriterioInvalidoError  .! !TestCase subclass: #FutbolistasTest	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1 -Casos-de-Uso'!!FutbolistasTest methodsFor: 'tests' stamp: 'Gonzalo 10/16/2025 23:29'!test07EdadInvalida	"Arrange"	| bloque |		bloque := [ Edad clasificacion: -25 ].			"Assert"	self should: bloque raise: ValorInvalidoError .! !!FutbolistasTest methodsFor: 'tests' stamp: 'Gonzalo 10/17/2025 09:03'!test04FutbolistaEdadInvalida	"Arrange"	| bloque |		bloque := [ Futbolista		conNombre: ' Martegani ' dePeso: 70 yAltura: 180  yEdad: -1 yProvenienteDelClub: 'San Lorenzo' dePais: 'Argentina' ].			"Act y Assert "	self should: bloque raise: ValorInvalidoError .! !!FutbolistasTest methodsFor: 'tests' stamp: 'Gonzalo 10/16/2025 12:08'!test02FutbolistaPesoInvalido	"Arrange"	| bloque |		bloque := [ Futbolista 		conNombre: ' Martegani ' dePeso: -70 yAltura: 180  yEdad: 25 yProvenienteDelClub: 'San Lorenzo' dePais: 'Argentina' ].		"Assert"	self should: bloque raise: ValorInvalidoError .! !!FutbolistasTest methodsFor: 'tests' stamp: 'Gonzalo 10/16/2025 12:08'!test05EdadInstancia	"Arrange"	| inicializado joven |	joven := Joven new.		"Act"	inicializado := joven inicializarCon: 25.		"Assert"	self assert: inicializado == joven. 	! !!FutbolistasTest methodsFor: 'tests' stamp: 'Gonzalo 10/17/2025 09:02'!test06PesoYAlturaInvalidos	"Arrange"	| bloque  |	bloque := [ 			Futbolista conNombre: 'Martegani' dePeso: -1 yAltura: -1 yEdad:  25 yProvenienteDelClub:'San Lorenzo'  dePais: 'Argentina'		 ].		"Act y Assert"	self should: bloque raise: ValorInvalidoError.! !!FutbolistasTest methodsFor: 'tests' stamp: 'Gonzalo 10/17/2025 09:03'!test03FutbolistaAlturaInvalida	"Arrange"	| bloque |		bloque := [ Futbolista 		conNombre: ' Martegani ' dePeso: 70 yAltura: -180  yEdad: 25 yProvenienteDelClub: 'San Lorenzo' dePais: 'Argentina' ].		"Act y Assert"	self should: bloque raise: ValorInvalidoError .! !TestCase subclass: #ValorTests	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1 -Casos-de-Uso'!!ValorTests methodsFor: 'tests' stamp: 'Gonzalo 10/16/2025 12:15'!test03InicializarConDevuelveSelf	"Arrange"	|valor resultado|	valor := Valor new.		"Act"	resultado := valor inicializarCon:  100.		"Assert"	self assert: resultado equals: valor .! !!ValorTests methodsFor: 'tests' stamp: 'Gonzalo 10/16/2025 12:14'!test01ComparacionConPrecision	"Arrange"	|valor |		"Act"	valor := Valor new inicializarCon: 100.		"Assert"	self assert: (valor compararCon: 101 precision: 199)! !!ValorTests methodsFor: 'tests' stamp: 'Gonzalo 10/16/2025 12:15'!test04InicializarConValor	"Arrange"	|valor|	valor := Valor new inicializarCon:  100.	"Assert"	self assert: valor monto = 100.	! !!ValorTests methodsFor: 'tests' stamp: 'Gonzalo 10/16/2025 12:14'!test02ComparacionEnReales	"Arrange"	|valor resultado|	valor := Valor new inicializarCon: 245.0.		"Act"	resultado := valor compararConValorEnReales: 1 precision: 0.01.		"Assert"	self assert: resultado .! !