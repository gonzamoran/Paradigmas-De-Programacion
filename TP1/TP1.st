Object subclass: #AlgoConsejo	instanceVariableNames: 'criterio futbolistas'	classVariableNames: ''	package: 'TP1'!!AlgoConsejo methodsFor: 'as yet unclassified' stamp: 'Gonzalo 9/23/2025 16:29'!conCriterioMas: unCriterio	criterio := Criterio conCriterio: unCriterio.! !!AlgoConsejo methodsFor: 'as yet unclassified' stamp: 'Gonzalo 9/24/2025 18:07'!registrarFutbolistaConNombre: unNombre dePeso: unPeso  yAltura: unaAltura yEdad: unaEdad yProvenienteDelClub: unClub DePais: unPais	 | futbolista | 	futbolista := Futbolista conNombre: unNombre dePeso: unPeso yAltura: unaAltura yEdad: unaEdad yProvenienteDelClub: unClub dePais: unPais.	futbolistas add: futbolista.! !!AlgoConsejo methodsFor: 'not defined category' stamp: 'Gonzalo 10/17/2025 08:59'!obtenerFutbolistaSegunCriterio	futbolistas isEmpty ifTrue: [ ColeccionVaciaError signal ].	^ criterio nombreSeleccionadoDe:  futbolistas ! !!AlgoConsejo methodsFor: 'not defined category' stamp: 'Gonzalo 10/17/2025 08:42'!valorDe: unJugador	^ ((futbolistas detect: [ :x | x tieneNombre: unJugador ] ifNone: [FutbolistaNoEncontradoError signal ]) valor )! !!AlgoConsejo methodsFor: 'initialization' stamp: 'Gonzalo 9/21/2025 23:02'!initialize	futbolistas := OrderedCollection new! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!AlgoConsejo class	instanceVariableNames: ''!!AlgoConsejo class methodsFor: 'not defined category' stamp: 'Gonzalo 9/23/2025 16:29'!conCriterioMas: unCriterio	| algoConsejo |	algoConsejo := self new.	algoConsejo  conCriterioMas: unCriterio.	^algoConsejo ! !Error subclass: #ColeccionVaciaError	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!Object subclass: #Criterio	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Criterio methodsFor: 'not defined category' stamp: 'Gonzalo 10/17/2025 08:58'!nombreSeleccionadoDe: futbolistas	| futbolista |	futbolista := self seleccionarDe: futbolistas.	^ futbolista nombrePropio! !!Criterio methodsFor: 'as yet unclassified' stamp: 'Gonzalo 9/22/2025 01:00'!seleccionarDe: unosFutbolistas	self subclassResponsibility 	! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Criterio class	instanceVariableNames: ''!!Criterio class methodsFor: 'not defined category' stamp: 'Gonzalo 9/24/2025 19:33'!conCriterio: unCriterio	(unCriterio = 'Caro') ifTrue: [ ^Caro new ].	(unCriterio  = 'Barato') ifTrue: [ ^Barato new ].	CriterioInvalidoError signal.	! !Criterio subclass: #Barato	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Barato methodsFor: 'not defined category' stamp: 'Gonzalo 10/16/2025 11:34'!seleccionarDe: unaColeccion	^ (unaColeccion detectMin: [:f | f valorNumerico ])! !Criterio subclass: #Caro	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Caro methodsFor: 'not defined category' stamp: 'Gonzalo 10/16/2025 17:58'!seleccionarDe: unaColeccion	^ (unaColeccion detectMax: [:f | f valorNumerico  ])! !Error subclass: #CriterioInvalidoError	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!Object subclass: #Edad	instanceVariableNames: 'edadJugador'	classVariableNames: ''	package: 'TP1'!!Edad methodsFor: 'as yet unclassified' stamp: 'Gonzalo 9/22/2025 00:16'!calcularValorConPeso: unPeso altura: unaAltura	self subclassResponsibility ! !!Edad methodsFor: 'not defined category' stamp: 'Gonzalo 9/25/2025 14:15'!inicializarCon: unaEdad	edadJugador := unaEdad ! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Edad class	instanceVariableNames: ''!!Edad class methodsFor: 'not defined category' stamp: 'Gonzalo 10/16/2025 23:37'!clasificacion: unaEdad	(unaEdad < 0) ifTrue: [ ValorInvalidoError  signal].	(unaEdad < 33) ifTrue: [ ^ Joven  new inicializarCon: unaEdad ].	 ^ Veterano new inicializarCon: unaEdad.! !Object subclass: #Futbolista	instanceVariableNames: 'nombre pais edad altura peso club'	classVariableNames: ''	package: 'TP1'!!Futbolista methodsFor: 'not defined category' stamp: 'Gonzalo 10/16/2025 23:46'!conNombre: unNombre dePeso: unPeso  yAltura: unaAltura yEdad: unaEdad yProvenienteDelClub: unClub dePais: unPais	(self mayorACero: unPeso  ) ifFalse:   [ValorInvalidoError signal ].	(self mayorACero: unaAltura ) ifFalse:  [ValorInvalidoError signal ].	Edad clasificacion: unaEdad .		nombre := unNombre. 	peso := unPeso.	altura := unaAltura.	edad :=  unaEdad .	club := unClub .	pais := Pais dePais: unPais.	! !!Futbolista methodsFor: 'not defined category' stamp: 'Gonzalo 10/16/2025 23:32'!mayorACero: unNumero	^ (unNumero > 0)! !!Futbolista methodsFor: 'not defined category' stamp: 'Gonzalo 10/16/2025 09:52'!tieneNombre: unNombre	^  nombre = unNombre ! !!Futbolista methodsFor: 'not defined category' stamp: 'Gonzalo 9/24/2025 17:42'!valor	^ Valor deUnValor:  peso altura: altura edad: edad pais: pais. ! !!Futbolista methodsFor: 'not defined category' stamp: 'Gonzalo 10/16/2025 11:34'!valorNumerico	^ self valor monto! !!Futbolista methodsFor: 'accessing' stamp: 'Gonzalo 10/17/2025 08:39'!nombrePropio	^ nombre ! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Futbolista class	instanceVariableNames: ''!!Futbolista class methodsFor: 'not defined category' stamp: 'Gonzalo 9/23/2025 16:47'!conNombre: unNombre dePeso: unPeso  yAltura: unaAltura yEdad: unaEdad yProvenienteDelClub: unClub dePais: unPais	| unFutbolista |	unFutbolista := self new.	unFutbolista conNombre: unNombre dePeso: unPeso yAltura: unaAltura yEdad: unaEdad yProvenienteDelClub: unClub dePais: unPais.	^ unFutbolista 	! !Error subclass: #FutbolistaNoEncontradoError	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!Edad subclass: #Joven	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Joven methodsFor: 'not defined category' stamp: 'Gonzalo 9/25/2025 13:45'!calcularValorConPeso:  unPeso altura: unaAltura	^ (unPeso * unaAltura ) /  edadJugador ! !Object subclass: #Pais	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Pais methodsFor: 'as yet unclassified' stamp: 'Gonzalo 9/22/2025 23:39'!multiplicadorDeValor: unValor	self subclassResponsibility   ! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Pais class	instanceVariableNames: ''!!Pais class methodsFor: 'not defined category' stamp: 'Gonzalo 9/24/2025 18:14'!dePais: unPais	(unPais  = 'Argentina') ifTrue: [ ^ Argentina new].	(#('Bolivia' 'Brasil' 'Chile' 'Colombia' 'Ecuador' 'Paraguay' 'Peru' 'Uruguay' 'Venezuela' ) includes: unPais ) ifTrue: [ ^ Conmebol new ].	^ FueraConmebol new.! !Pais subclass: #Argentina	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Argentina methodsFor: 'not defined category' stamp: 'Gonzalo 9/22/2025 23:38'!multiplicadorDeValor: unValor	^ (unValor * 1.10)! !Pais subclass: #Conmebol	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Conmebol methodsFor: 'not defined category' stamp: 'Gonzalo 9/22/2025 23:41'!multiplicadorDeValor: unValor	^ (unValor * 1.25)! !Pais subclass: #FueraConmebol	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!FueraConmebol methodsFor: 'not defined category' stamp: 'Gonzalo 9/22/2025 23:41'!multiplicadorDeValor: unValor	^ (unValor * 1.50)! !Object subclass: #Valor	instanceVariableNames: 'valor altura edad pais monto'	classVariableNames: ''	package: 'TP1'!!Valor methodsFor: 'not defined category' stamp: 'Gonzalo 9/25/2025 01:58'!compararCon: unValor precision: unaPrecision	^ (monto - unValor ) abs < unaPrecision.	! !!Valor methodsFor: 'not defined category' stamp: 'Gonzalo 9/25/2025 14:16'!inicializarCon: unNumero	monto := unNumero.	! !!Valor methodsFor: 'not defined category' stamp: 'Gonzalo 9/25/2025 01:59'!compararConValorEnReales: unNumero precision: unaPrecision	^ ((monto / 245.0) - unNumero ) abs < unaPrecision! !!Valor methodsFor: 'accessing' stamp: 'Gonzalo 9/24/2025 17:42'!monto	^ monto! !!Valor methodsFor: 'as yet unclassified' stamp: 'Gonzalo 9/24/2025 17:27'!deUnValor:  unValor unaAltura: unaAltura unaEdad: unaEdad yUnPais: unPais	valor := unValor.	altura := unaAltura.  	edad := unaEdad.	pais := unPais.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Valor class	instanceVariableNames: ''!!Valor class methodsFor: 'not defined category' stamp: 'Gonzalo 9/25/2025 14:05'!deUnValor: unPeso altura: unaAltura edad: unaEdad pais: unPais	| edadObj base total |	edadObj := Edad clasificacion: unaEdad.	base := edadObj calcularValorConPeso:  unPeso altura: unaAltura.	total :=  unPais multiplicadorDeValor: base.	^ self new inicializarCon: total.	! !Error subclass: #ValorInvalidoError	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!Edad subclass: #Veterano	instanceVariableNames: ''	classVariableNames: ''	package: 'TP1'!!Veterano methodsFor: 'not defined category' stamp: 'Gonzalo 9/22/2025 00:21'!calcularValorConPeso:  unPeso altura: unaAltura	^ (100 * unPeso * (unaAltura sqrt )) / (edadJugador raisedTo: 3)! !